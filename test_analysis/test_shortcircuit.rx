// Test 5: Short-circuit boolean chains (phi-intensive)

fn is_pos(x: i32) -> bool { x > 0 }
fn is_even(x: i32) -> bool { x % 2 == 0 }

fn and_chain(a: i32, b: i32, c: i32) -> bool {
    is_pos(a) && is_even(b) && is_pos(c)
}

fn or_chain(a: i32, b: i32, c: i32) -> bool {
    a < 0 || b < 0 || c < 0
}

fn mixed_chain(a: i32, b: i32, c: i32, d: i32) -> bool {
    (is_pos(a) && is_even(b)) || (is_pos(c) && is_even(d))
}

fn deep_and(a1: i32, a2: i32, a3: i32, a4: i32, a5: i32) -> bool {
    a1 > 0 && a2 > 0 && a3 > 0 && a4 > 0 && a5 > 0
}

fn main() {
    let mut count: i32 = 0;
    let mut x: i32 = 0;
    while (x < 50000) {
        if (and_chain(x, x+1, x+2)) { count = count + 1; }
        if (or_chain(x, x+1, x+2)) { count = count + 1; }
        if (mixed_chain(x, x+1, x+2, x+3)) { count = count + 1; }
        if (deep_and(x, x+1, x+2, x+3, x+4)) { count = count + 1; }
        x = x + 1;
    }
    printlnInt(count);
    exit(0);
}
